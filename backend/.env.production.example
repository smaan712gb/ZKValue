# ============================================================
# ZKValue Production Environment Configuration
# ============================================================
# IMPORTANT: Copy this to .env and fill in real values.
#            NEVER commit .env files with real secrets.
#            Use a secrets manager (AWS SSM, Vault, etc.) in production.
# ============================================================

# --- Database (REQUIRED) ---
DATABASE_URL=postgresql+asyncpg://zkvalue:<STRONG_PASSWORD>@postgres:5432/zkvalue

# --- Redis (REQUIRED) ---
REDIS_URL=redis://redis:6379/0

# --- Security (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=<GENERATE_A_64_CHAR_SECRET>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- LLM Providers (at least ONE required) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-chat

# --- Stripe Billing (REQUIRED in production) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...

# --- Sentry Error Tracking (RECOMMENDED) ---
SENTRY_DSN=https://<key>@sentry.io/<project_id>

# --- AWS S3 Storage (REQUIRED for report storage) ---
S3_BUCKET=zkvalue-reports-prod
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1

# --- Blockchain Anchoring (OPTIONAL — simulation mode if not set) ---
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=

# --- CORS (set to your actual domain) ---
CORS_ORIGINS=["https://app.zkvalue.com"]

# --- App ---
APP_NAME=ZKValue
APP_VERSION=1.0.0
ENVIRONMENT=production
FRONTEND_URL=https://app.zkvalue.com

# --- PostgreSQL (used by docker-compose for DB init) ---
POSTGRES_USER=zkvalue
POSTGRES_PASSWORD=<STRONG_PASSWORD_MATCHING_DATABASE_URL>
POSTGRES_DB=zkvalue
