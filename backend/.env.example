# ZKValue Backend Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://zkvalue:zkvalue_secret_2026@localhost:5432/zkvalue

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# DeepSeek (Default LLM Provider)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI (Optional - for orgs that choose OpenAI)
OPENAI_API_KEY=

# Anthropic (Optional - for orgs that choose Anthropic)
ANTHROPIC_API_KEY=

# Default LLM Configuration
DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-chat

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Sentry Error Tracking (Optional)
SENTRY_DSN=

# AWS S3 (for report/certificate storage)
S3_BUCKET=zkvalue-reports
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# App
APP_NAME=ZKValue
APP_VERSION=1.0.0
ENVIRONMENT=development
